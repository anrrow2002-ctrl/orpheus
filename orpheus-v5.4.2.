{
  "type": "script",
  "enabled": true,
  "name": "Orpheus Loader v5.4.2",
  "id": "orpheus-loader",
  "content": "(function(){\n  const ROOT = window.parent && window.parent.document ? window.parent : window;\n  const DOC = ROOT.document;\n  const URL = 'https://cdn.jsdelivr.net/gh/anrrow2002-ctrl/orpheus@main/orpheus-v5.4.2.json';\n\n  fetch(URL, { cache: 'no-cache' })\n    .then(function(r){\n      if (!r.ok) throw new Error('HTTP ' + r.status);\n      return r.json();\n    })\n    .then(function(pack){\n      if (!pack || typeof pack.content !== 'string') {\n        throw new Error('远程 JSON 里没有 content 脚本');\n      }\n\n      const old = DOC.getElementById('orpheus-remote-script');\n      if (old) old.remove();\n\n      const blob = new Blob([pack.content], { type: 'text/javascript' });\n      const blobUrl = ROOT.URL.createObjectURL(blob);\n      const s = DOC.createElement('script');\n      s.id = 'orpheus-remote-script';\n      s.src = blobUrl;\n      s.onload = function(){\n        console.log('[Orpheus] 已加载远程脚本:', URL);\n        ROOT.URL.revokeObjectURL(blobUrl);\n      };\n      s.onerror = function(){\n        ROOT.URL.revokeObjectURL(blobUrl);\n        alert('Orpheus 远程脚本执行失败');\n      };\n      DOC.head.appendChild(s);\n    })\n    .catch(function(e){\n      console.error('[Orpheus Loader]', e);\n      alert('Orpheus 加载失败：' + e.message + '\\n请检查 GitHub/jsDelivr 链接是否正确。');\n    });\n})();"
}
